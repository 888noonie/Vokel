# === VOKEL CONFIG (Co-built with Grok) ===

# Local LLM (OpenAI-compatible)
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model-name

# Tool APIs (optional but powerful)
SERPAPI_API_KEY=your_serpapi_key_here          # for high-quality web search
UNSPLASH_ACCESS_KEY=your_unsplash_key_here
GIPHY_API_KEY=your_giphy_key_here

# Memory (local, opt-in)
MEMORY_ENABLED=false
MEMORY_DB_PATH=./vokel_memory.db

# Voice / Audio tuning
DEFAULT_VOICE=af_bella                    # see 28 Kokoro voices
SPEED=1.0
